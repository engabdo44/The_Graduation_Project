generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model applications {
  application_id BigInt                      @id @default(autoincrement()) @db.UnsignedBigInt
  applicant_type applications_applicant_type
  citizen_id     BigInt?                     @db.UnsignedBigInt
  resident_id    BigInt?                     @db.UnsignedBigInt
  service_type   String                      @db.VarChar(100)
  status         applications_status?        @default(submitted)
  request_date   DateTime?                   @default(now()) @db.DateTime(0)
  approval_date  DateTime?                   @db.DateTime(0)
  citizens       citizens?                   @relation(fields: [citizen_id], references: [citizen_id])
  residents      residents?                  @relation(fields: [resident_id], references: [resident_id])
  appointments   appointments[]
  payments       payments[]

  @@index([citizen_id], map: "applications_citizen_id_fkey")
  @@index([resident_id], map: "applications_resident_id_fkey")
}

model appointments {
  appointment_id BigInt               @id @default(autoincrement()) @db.UnsignedBigInt
  application_id BigInt?              @db.UnsignedBigInt
  service_type   String?              @db.VarChar(100)
  date_time      DateTime             @db.DateTime(0)
  status         appointments_status? @default(booked)
  applications   applications?        @relation(fields: [application_id], references: [application_id])

  @@index([application_id], map: "appointments_application_id_fkey")
}

model citizen_id_cards {
  id_card_id   BigInt                   @id @default(autoincrement()) @db.UnsignedBigInt
  citizen_id   BigInt                   @db.UnsignedBigInt
  issue_number Int                      @default(1) @db.UnsignedInt
  issue_date   DateTime                 @db.Date
  expiry_date  DateTime                 @db.Date
  status       citizen_id_cards_status? @default(active)
  citizens     citizens                 @relation(fields: [citizen_id], references: [citizen_id], onDelete: Cascade)

  @@index([citizen_id], map: "citizen_id_cards_citizen_id_fkey")
}

model citizens {
  citizen_id          BigInt                   @id @default(autoincrement()) @db.UnsignedBigInt
  national_number     String                   @unique @db.VarChar(20)
  full_name           String                   @db.VarChar(200)
  dob                 DateTime                 @db.Date
  gender              citizens_gender
  nationality         String?                  @default("Somali") @db.VarChar(80)
  marital_status      citizens_marital_status? @default(single)
  address             String?                  @db.Text
  phone               String?                  @db.VarChar(30)
  email               String?                  @db.VarChar(120)
  status              citizens_status?         @default(active)
  created_at          DateTime?                @default(now()) @db.DateTime(0)
  updated_at          DateTime?                @default(now()) @db.DateTime(0)
  applications        applications[]
  citizen_id_cards    citizen_id_cards[]
  families            families[]
  family_members      family_members[]
  passports           passports[]
  travel_restrictions travel_restrictions[]

  users               users?
}

model criminal_records {
  record_id      BigInt                    @id @default(autoincrement()) @db.UnsignedBigInt
  id_number      String                    @db.VarChar(11)
  crime_type     String                    @db.VarChar(150)
  severity       criminal_records_severity @default(C)
  incident_date  DateTime?                 @db.Date
  court_decision String?                   @db.Text
  status         criminal_records_status?  @default(open)
}

model resident_criminal_records {
  record_id      BigInt                    @id @default(autoincrement()) @db.UnsignedBigInt
  residence_number String                  @db.VarChar(20)
  crime_type     String                    @db.VarChar(150)
  severity       criminal_records_severity @default(C)
  incident_date  DateTime?                 @db.Date
  court_decision String?                   @db.Text
  status         criminal_records_status?  @default(open)
}


enum criminal_records_severity {
  A
  B
  C
  D
  E
  F
}


model employees {
  employee_id BigInt            @id @default(autoincrement()) @db.UnsignedBigInt
  full_name   String            @db.VarChar(200)
  role        String            @db.VarChar(60)
  department  String?           @db.VarChar(100)
  phone       String?           @db.VarChar(30)
  email       String?           @db.VarChar(120)
  status      employees_status? @default(active)
  created_at  DateTime?         @default(now()) @db.DateTime(0)
  system_logs system_logs[]
  users       users[]
}

model families {
  family_id       BigInt           @id @default(autoincrement()) @db.UnsignedBigInt
  head_citizen_id BigInt           @db.UnsignedBigInt
  citizens        citizens         @relation(fields: [head_citizen_id], references: [citizen_id])
  family_members  family_members[]

  @@index([head_citizen_id], map: "families_head_citizen_id_fkey")
}

model family_members {
  member_id  BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  family_id  BigInt   @db.UnsignedBigInt
  citizen_id BigInt   @db.UnsignedBigInt
  relation   String?  @db.VarChar(60)
  citizens   citizens @relation(fields: [citizen_id], references: [citizen_id], onDelete: Cascade)
  families   families @relation(fields: [family_id], references: [family_id], onDelete: Cascade)

  @@index([citizen_id], map: "family_members_citizen_id_fkey")
  @@index([family_id], map: "family_members_family_id_fkey")
}

model notifications {
  notification_id BigInt                @id @default(autoincrement()) @db.UnsignedBigInt
  user_id         BigInt                @db.UnsignedBigInt
  message         String                @db.Text
  date_sent       DateTime?             @default(now()) @db.DateTime(0)
  status          notifications_status? @default(sent)
  users           users                 @relation(fields: [user_id], references: [user_id], onDelete: Cascade)

  @@index([user_id], map: "notifications_user_id_fkey")
}

model passports {
  passport_id     BigInt            @id @default(autoincrement()) @db.UnsignedBigInt
  citizen_id      BigInt            @db.UnsignedBigInt
  passport_number String            @unique @db.VarChar(50)
  type            passports_type
  issue_date      DateTime          @db.Date
  expiry_date     DateTime          @db.Date
  status          passports_status? @default(active)
  citizens        citizens          @relation(fields: [citizen_id], references: [citizen_id])

  @@index([citizen_id], map: "passports_citizen_id_fkey")
}

model payments {
  payment_id     BigInt                  @id @default(autoincrement()) @db.UnsignedBigInt
  application_id BigInt?                 @db.UnsignedBigInt
  amount         Decimal                 @db.Decimal(12, 2)
  payment_method payments_payment_method
  status         payments_status?        @default(paid)
  payment_date   DateTime?               @default(now()) @db.DateTime(0)
  applications   applications?           @relation(fields: [application_id], references: [application_id])

  @@index([application_id], map: "payments_application_id_fkey")
}

model resident_id_cards {
  id_card_id   BigInt                    @id @default(autoincrement()) @db.UnsignedBigInt
  resident_id  BigInt                    @db.UnsignedBigInt
  issue_number Int                       @default(1) @db.UnsignedInt
  issue_date   DateTime                  @db.Date
  expiry_date  DateTime                  @db.Date
  status       resident_id_cards_status? @default(active)
  residents    residents                 @relation(fields: [resident_id], references: [resident_id], onDelete: Cascade)

  @@index([resident_id], map: "resident_id_cards_resident_id_fkey")
}

model residents {
  resident_id         BigInt                @id @default(autoincrement()) @db.UnsignedBigInt
  residence_number    String                @unique @db.VarChar(20)
  full_name           String                @db.VarChar(200)
  dob                 DateTime              @db.Date
  gender              residents_gender
  nationality         String                @db.VarChar(100)
  passport_number     String?               @db.VarChar(50)
  visa_type           String?               @db.VarChar(100)
  sponsor_name        String?               @db.VarChar(200)
  address             String?               @db.Text
  phone               String?               @db.VarChar(30)
  email               String?               @db.VarChar(120)
  status              residents_status?     @default(active)
  created_at          DateTime?             @default(now()) @db.DateTime(0)
  updated_at          DateTime?             @default(now()) @db.DateTime(0)
  applications        applications[]
  resident_id_cards   resident_id_cards[]
  travel_restrictions travel_restrictions[]
  users               users?
}

model system_logs {
  log_id      BigInt     @id @default(autoincrement()) @db.UnsignedBigInt
  employee_id BigInt?    @db.UnsignedBigInt
  action      String     @db.VarChar(255)
  date_time   DateTime?  @default(now()) @db.DateTime(0)
  employees   employees? @relation(fields: [employee_id], references: [employee_id])

  @@index([employee_id], map: "system_logs_employee_id_fkey")
}

model travel_restrictions {
  restriction_id BigInt                      @id @default(autoincrement()) @db.UnsignedBigInt
  citizen_id     BigInt?                     @db.UnsignedBigInt
  resident_id    BigInt?                     @db.UnsignedBigInt
  reason         String                      @db.Text
  start_date     DateTime                    @db.Date
  end_date       DateTime?                   @db.Date
  status         travel_restrictions_status? @default(active)
  citizens       citizens?                   @relation(fields: [citizen_id], references: [citizen_id])
  residents      residents?                  @relation(fields: [resident_id], references: [resident_id])

  @@index([citizen_id], map: "travel_restrictions_citizen_id_fkey")
  @@index([resident_id], map: "travel_restrictions_resident_id_fkey")
}

model users {
  user_id       BigInt             @id @default(autoincrement()) @db.UnsignedBigInt
  citizen_id    BigInt?            @unique @db.UnsignedBigInt
  resident_id   BigInt?            @unique @db.UnsignedBigInt
  employee_id   BigInt?            @db.UnsignedBigInt
  username      String             @unique @db.VarChar(50)
  email         String             @unique @db.VarChar(120)
  password_hash String             @db.VarChar(255)
  account_type  users_account_type
  is_active     Boolean?           @default(true)
  last_login    DateTime?          @db.DateTime(0)
  created_at    DateTime?          @default(now()) @db.DateTime(0)
  notifications notifications[]
  citizens      citizens?          @relation(fields: [citizen_id], references: [citizen_id], onDelete: Cascade)
  employees     employees?         @relation(fields: [employee_id], references: [employee_id], onDelete: Cascade)
  residents     residents?         @relation(fields: [resident_id], references: [resident_id], onDelete: Cascade)

  @@index([employee_id], map: "users_employee_id_fkey")
}

enum applications_applicant_type {
  citizen
  resident
}

enum passports_type {
  regular
  diplomatic
  service
}

enum payments_payment_method {
  cash
  card
  mobile_money
}

enum appointments_status {
  booked
  completed
  cancelled
}

enum citizens_gender {
  male
  female
}

enum notifications_status {
  sent
  read
}

enum payments_status {
  paid
  pending
  failed
}

enum residents_gender {
  male
  female
}

enum applications_status {
  submitted
  under_review
  approved
  rejected
}

enum citizen_id_cards_status {
  active
  expired
  cancelled
}

enum criminal_records_status {
  open
  closed
}

enum resident_id_cards_status {
  active
  expired
  cancelled
}

enum citizens_marital_status {
  single
  married
  divorced
  widowed
}

enum employees_status {
  active
  inactive
}

enum passports_status {
  active
  expired
  cancelled
}

enum travel_restrictions_status {
  active
  expired
}

enum users_account_type {
  citizen
  resident
  admin
}

enum citizens_status {
  active
  inactive
  deceased
}

enum residents_status {
  active
  expired
  cancelled
}
